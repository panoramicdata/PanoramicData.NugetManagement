{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://panoramicdata/schemas/panoramicdata.nugetmanagement.test.secrets.schema.json",
  "title": "PanoramicData.NugetManagement.Test user secrets",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "GitHub": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Token": {
          "type": "string",
          "minLength": 1,
          "description": "GitHub API token used for integration-style tests that require authenticated API access."
        },
        "ApiBaseUrl": {
          "type": "string",
          "format": "uri",
          "default": "https://api.github.com",
          "description": "Base URL for the GitHub API."
        }
      },
      "required": [
        "Token"
      ]
    }
  }
}
