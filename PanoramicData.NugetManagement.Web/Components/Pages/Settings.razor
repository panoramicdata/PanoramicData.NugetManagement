@page "/settings"
@using Microsoft.Extensions.Options
@rendermode InteractiveServer
@inject IOptions<AppSettings> SettingsOptions
@inject RuntimeSettingsService RuntimeSettings
@inject LocalFileSystemDataProvider FileSystemDataProvider

<PageTitle>Settings</PageTitle>

<div style="max-width: 600px; margin: 0 auto;">
    <h1>⚙️ Settings</h1>
    <p style="color: var(--text-secondary);">
        These settings are read from user secrets. To update them, run:<br />
        <code style="color: var(--accent);">dotnet user-secrets set "AppSettings:KeyName" "value" --project PanoramicData.NugetManagement.Web</code>
    </p>

    <div class="settings-form">
        <div class="form-group">
            <label>GitHub Organization</label>
            <input type="text" value="@_settings.GitHubOrganization" readonly />
        </div>
        <div class="form-group">
            <label>NuGet Organization</label>
            <input type="text" value="@_settings.NuGetOrganization" readonly />
        </div>
        <div class="form-group">
            <label>GitHub OAuth Client ID</label>
            <input type="text" value="@MaskSecret(_settings.GitHubClientId)" readonly />
        </div>
        <div class="form-group">
            <label>GitHub OAuth Client Secret</label>
            <input type="text" value="@MaskSecret(_settings.GitHubClientSecret)" readonly />
        </div>
        <div class="form-group">
            <label>Expected License</label>
            <input type="text" value="@_settings.ExpectedLicense" readonly />
        </div>
        <div class="form-group">
            <label>Copyright Holder</label>
            <input type="text" value="@_settings.CopyrightHolder" readonly />
        </div>
        <div class="form-group">
            <label>Codacy API Token</label>
            <input type="text" value="@(string.IsNullOrEmpty(_settings.CodacyApiToken) ? "(not set)" : MaskSecret(_settings.CodacyApiToken))" readonly />
        </div>
        <div class="form-group">
            <label>Local Repos Root</label>
            <div style="display: flex; gap: 0.5rem; align-items: center;">
                <input type="text" value="@(_localReposRoot ?? "(auto-detected from working directory)")" readonly style="flex: 1;" />
                <button class="btn btn-primary btn-sm" @onclick="BrowseForFolder">📁 Browse</button>
                @if (_localReposRoot is not null)
                {
                    <button class="btn btn-sm btn-danger" @onclick="ClearLocalReposRoot" title="Reset to auto-detect">✕</button>
                }
            </div>
            @if (_folderSaved)
            {
                <span style="color: var(--success); font-size: 0.8rem;">✓ Saved</span>
            }
        </div>
    </div>

    <div style="margin-top: 2rem;">
        <a href="/" class="btn btn-primary">← Back to Dashboard</a>
    </div>
</div>

<PDFileModal @ref="_fileModal" DataProvider="FileSystemDataProvider" />

@code {
    private AppSettings _settings = new();
    private string? _localReposRoot;
    private bool _folderSaved;
    private PDFileModal? _fileModal;

    protected override void OnInitialized()
    {
        _settings = SettingsOptions.Value;
        _localReposRoot = RuntimeSettings.LocalReposRoot;
    }

    private async Task BrowseForFolder()
    {
        if (_fileModal is null)
        {
            return;
        }

        var result = await _fileModal.ShowOpenAndWaitResultAsync(folderSelect: true).ConfigureAwait(true);
        if (!string.IsNullOrEmpty(result))
        {
            var realPath = LocalFileSystemDataProvider.VirtualToRealPath(result);

            _localReposRoot = realPath;
            RuntimeSettings.SetLocalReposRoot(realPath);
            _folderSaved = true;
            StateHasChanged();

            // Clear the saved indicator after a short delay
            _ = Task.Delay(2000).ContinueWith(_ =>
            {
                _folderSaved = false;
                InvokeAsync(StateHasChanged);
            });
        }
    }

    private void ClearLocalReposRoot()
    {
        _localReposRoot = null;
        RuntimeSettings.SetLocalReposRoot(null);
        _folderSaved = true;
        StateHasChanged();

        _ = Task.Delay(2000).ContinueWith(_ =>
        {
            _folderSaved = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private static string MaskSecret(string? value)
    {
        if (string.IsNullOrEmpty(value))
        {
            return "(not set)";
        }

        if (value.Length <= 8)
        {
            return new string('•', value.Length);
        }

        return value[..4] + new string('•', value.Length - 8) + value[^4..];
    }
}
