	// === Console helpers ===

	private void AppendConsole(string line) { _consoleLines.Add(new ConsoleLine(line, GetConsoleLineClass(line))); _consoleScrollPending = true; }
	private void ClearConsole() { _consoleLines.Clear(); _lastPromptText = null; _copyFeedback = false; _consoleCopyFeedback = false; }

	private async Task CopyConsoleToClipboardAsync()
	{
		if (_consoleLines.Count == 0)
		{
			return;
		}

		try
		{
			var text = string.Join(Environment.NewLine, _consoleLines.ToArray().Select(l => l.Text));
			await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
			_consoleCopyFeedback = true;
			StateHasChanged();
			await Task.Delay(2000);
			_consoleCopyFeedback = false;
			StateHasChanged();
		}
		catch
		{
			AppendConsole("⚠️ Failed to copy to clipboard.");
		}
	}

	private async Task CopyPromptToClipboardAsync()
	{
		if (string.IsNullOrEmpty(_lastPromptText))
		{
			return;
		}

		try
		{
			await JS.InvokeVoidAsync("navigator.clipboard.writeText", _lastPromptText);
			_copyFeedback = true;
			StateHasChanged();
			await Task.Delay(2000);
			_copyFeedback = false;
			StateHasChanged();
		}
		catch
		{
			AppendConsole("⚠️ Failed to copy to clipboard.");
		}
	}

	// === Utility methods ===

	private string GetNavItemTooltip(NavItem item)
	{
		switch (item.View)
		{
			case NavView.Dashboard:
				var assessed = _rows.Count(r => r.Assessment is not null);
				return $"Dashboard — {_rows.Count} packages ({assessed} assessed, {item.IssueCount} issues)";

			case NavView.PackageDetail:
				var row = _rows.FirstOrDefault(r => r.PackageId == item.PackageId);
				if (row is null)
				{
					return item.PackageId ?? item.Text;
				}

				if (row.Assessment is null)
				{
					return $"{row.PackageId} — not yet assessed";
				}

				if (row.TotalFailures == 0)
				{
					return $"{row.PackageId} — all rules pass ✓ (green = compliant)";
				}

				if (row.TotalErrors > 0)
				{
					return $"{row.PackageId} — {row.TotalErrors} error(s), {row.TotalWarnings} warning(s) (red = errors found)";
				}

				return row.TotalWarnings > 0
					? $"{row.PackageId} — {row.TotalWarnings} warning(s) (amber = warnings only)"
					: $"{row.PackageId} — informational only (blue = info)";

			case NavView.CategoryDetail:
				if (item.IssueCount == 0)
				{
					return $"{item.Text} — all rules pass";
				}

				if (item.HasErrors)
				{
					return $"{item.Text} — {item.IssueCount} issue(s) including errors";
				}

				return item.HasWarnings
					? $"{item.Text} — {item.IssueCount} warning(s)"
					: $"{item.Text} — {item.IssueCount} informational";

			case NavView.RuleDetail:
				if (item.HasErrors)
				{
					return $"{item.Text} — error";
				}

				return item.HasWarnings
					? $"{item.Text} — warning"
					: $"{item.Text} — informational";

			default:
				return item.Text;
		}
	}

	private static string GetPackageHealthIcon(PackageDashboardRow row)
	{
		if (row.Assessment is null)
		{
			return "fas fa-spinner fa-spin text-muted";
		}

		if (row.TotalFailures == 0)
		{
			return "fas fa-cube text-success";
		}

		if (row.TotalErrors > 0)
		{
			return "fas fa-cube text-danger";
		}

		return row.TotalWarnings > 0
			? "fas fa-cube text-warning"
			: "fas fa-cube text-info";
	}

	private bool HasAutoRemediableFailures(AssessmentCategory category)
		=> _selectedRow?.Assessment?.RuleResults.Any(r => !r.Passed && r.Category == category && Dashboard.IsAutoRemediable(r)) == true;

	private List<CategoryGroup> GetGroupedFailures()
	{
		if (_selectedRow?.Assessment is null)
		{
			return [];
		}

		return _selectedRow.Assessment.RuleResults
			.Where(r => !r.Passed)
			.GroupBy(r => r.Category)
			.OrderBy(g => g.Key.ToString())
			.Select(g => new CategoryGroup { Category = g.Key, Failures = [.. g.OrderBy(r => r.RuleId)] })
			.ToList();
	}

	private static string GetGroupBadgeClass(CategoryGroup group)
		=> group.Failures.Any(f => f.Severity == AssessmentSeverity.Error) ? "badge-fail"
		 : group.Failures.Any(f => f.Severity == AssessmentSeverity.Warning) ? "badge-warn"
		 : "badge-info";

	private static string GetSeverityBadgeClass(RuleResult result) => result.Severity switch
	{
		AssessmentSeverity.Error => "badge-fail",
		AssessmentSeverity.Warning => "badge-warn",
		_ => "badge-info"
	};

	private static string GetConsoleLineClass(string line)
		=> line.StartsWith("✅") ? "console-line console-success"
		 : line.StartsWith("❌") ? "console-line console-error"
		 : line.StartsWith("▶") ? "console-line console-action"
		 : line.StartsWith("──") ? "console-line console-divider"
		 : "console-line";

	private static string FormatDataValue(object? value)
		=> value is string s && s.Length > 200 ? s[..200] + "…" : value?.ToString() ?? "(null)";

	// === Settings methods ===

	private async Task BrowseForFolder()
	{
		if (_fileModal is null)
		{
			return;
		}

		var result = await _fileModal.ShowOpenAndWaitResultAsync(folderSelect: true).ConfigureAwait(true);
		if (!string.IsNullOrEmpty(result))
		{
			_localReposRoot = LocalFileSystemDataProvider.VirtualToRealPath(result);
			RuntimeSettings.SetLocalReposRoot(_localReposRoot);
			_folderSaved = true;
			StateHasChanged();
			_ = Task.Delay(2000).ContinueWith(_ => { _folderSaved = false; InvokeAsync(StateHasChanged); });
		}
	}

	private void ClearLocalReposRoot()
	{
		_localReposRoot = null;
		RuntimeSettings.SetLocalReposRoot(null);
		_folderSaved = true;
		StateHasChanged();
		_ = Task.Delay(2000).ContinueWith(_ => { _folderSaved = false; InvokeAsync(StateHasChanged); });
	}

	private void OnPreferredIdeChanged(ChangeEventArgs e)
	{
		var value = e.Value?.ToString();
		_preferredIdeId = string.IsNullOrEmpty(value) ? null : value;
		RuntimeSettings.SetPreferredIdeId(_preferredIdeId);
		StateHasChanged();
	}

	// === IDE methods ===

	private InstalledIde? GetPreferredIde()
	{
		var ides = IdeDetection.DetectedIdes;
		if (ides.Count == 0)
		{
			return null;
		}

		if (_preferredIdeId is not null)
		{
			var preferred = ides.FirstOrDefault(i => i.Id == _preferredIdeId);
			if (preferred is not null)
			{
				return preferred;
			}
		}

		// Use auto-default priority when user hasn't chosen
		var defaultId = IdeDetection.GetDefaultIdeId();
		return defaultId is not null
			? ides.FirstOrDefault(i => i.Id == defaultId) ?? ides[0]
			: ides[0];
	}

	private string GetPreferredIdeIcon()
		=> GetPreferredIde()?.IconCss ?? "fas fa-external-link-alt";

	private void OpenInIde()
	{
		if (_selectedRow is null)
		{
			AppendConsole("❌ No package selected.");
			StateHasChanged();
			return;
		}

		if (_selectedRow.LocalPath is null)
		{
			AppendConsole("❌ Repository path not set. Run Git Sync/Clone first.");
			StateHasChanged();
			return;
		}

		if (!Directory.Exists(_selectedRow.LocalPath))
		{
			AppendConsole($"❌ Repository folder not found: {_selectedRow.LocalPath}");
			StateHasChanged();
			return;
		}

		var ide = GetPreferredIde();
		if (ide is null)
		{
			AppendConsole("❌ No supported IDE detected. Install Visual Studio, VS Code, or JetBrains Rider.");
			StateHasChanged();
			return;
		}

		try
		{
			var process = IdeDetection.OpenInIde(ide, _selectedRow.LocalPath);
			var pidInfo = process is not null ? $" (PID {process.Id})" : "";
			AppendConsole($"✅ Opened {_selectedRow.PackageId} in {ide.DisplayName}{pidInfo}");
		}
		catch (Exception ex)
		{
			AppendConsole($"❌ Failed to open IDE: {ex.Message}");
		}

		StateHasChanged();
	}

	private async Task FixWithAiAsync()
	{
		if (_selectedRow is null)
		{
			return;
		}

		_isRunning = true;
		_activeWorkflowStep = WorkflowStep.FixWithAi;

		// Open the IDE
		OpenInIde();

		try
		{
			if (_lastFailedWorkflowStep is WorkflowStep.Build or WorkflowStep.Test)
			{
				await ResolveWorkflowFailureAsync(_lastFailedWorkflowStep.Value);
			}
			else
			{
				await ResolveAllAsync();
			}

			_completedSteps.Add(WorkflowStep.FixWithAi);
		}
		finally
		{
			_activeWorkflowStep = null;
			_isRunning = false;
			StateHasChanged();
		}
	}

	private bool IsFixWithAiEnabled()
	{
		if (_selectedRow is null || _isRunning)
		{
			return false;
		}

		if (_selectedRow.Assessment is null && _lastFailedWorkflowStep is not WorkflowStep.Build and not WorkflowStep.Test)
		{
			return false;
		}

		if (!_selectedRow.IsClonedLocally || _selectedRow.LocalPath is null)
		{
			return false;
		}

		var hasWorkflowFailure = _lastFailedWorkflowStep is WorkflowStep.Build or WorkflowStep.Test;
     var ruleResults = _selectedRow.Assessment?.RuleResults;
		var hasFailures = ruleResults?.Any(r => !r.Passed) == true;

		if (hasWorkflowFailure)
		{
			return true;
		}

		if (!hasFailures)
		{
			return false;
		}

		// Enabled when there are non-auto-remediable failures,
		// OR when Fix has already been run but failures still remain
		// (indicating auto-fix couldn't resolve them)
     var hasManualOnly = ruleResults?.Any(r => !r.Passed && !Dashboard.IsAutoRemediable(r)) == true;

		return hasManualOnly || IsStepDone(WorkflowStep.Fix);
	}

	private bool IsOpenIdeEnabled()
	{
		if (_selectedRow is null || _isRunning)
		{
			return false;
		}

		if (_selectedRow.LocalPath is null)
		{
			return false;
		}

		return Directory.Exists(_selectedRow.LocalPath);
	}

	private string GetOpenIdeTooltip()
	{
		if (_selectedRow is null)
		{
			return "Select a package first";
		}

		if (_isRunning)
		{
			return "Another operation is running";
		}

		if (_selectedRow.LocalPath is null)
		{
			return "Run Git Sync to clone the repository first";
		}

		if (!Directory.Exists(_selectedRow.LocalPath))
		{
			return "Repository folder is missing locally";
		}

		return "Open selected repository in IDE";
	}

	private string GetFixWithAiTooltip()
	{
		if (_selectedRow is null)
		{
			return "Select a package first";
		}

		if (_lastFailedWorkflowStep == WorkflowStep.Build)
		{
			return "Copy AI prompt for the latest build failure";
		}

		if (_lastFailedWorkflowStep == WorkflowStep.Test)
		{
			return "Copy AI prompt for the latest test failure";
		}

		if (_selectedRow.Assessment is null)
		{
			return "Assess the package first";
		}

		if (!_selectedRow.IsClonedLocally)
		{
			return "Clone the repository first";
		}

		var remainingCount = _selectedRow.Assessment.RuleResults
			.Count(r => !r.Passed);

		if (remainingCount == 0)
		{
			return "No issues remaining";
		}

		var manualCount = _selectedRow.Assessment.RuleResults
			.Count(r => !r.Passed && !Dashboard.IsAutoRemediable(r));

		if (manualCount == 0 && !IsStepDone(WorkflowStep.Fix))
		{
			return "Run Fix first — all remaining issues may be auto-fixable";
		}

		return $"Copy AI prompt for {remainingCount} remaining issue{(remainingCount == 1 ? "" : "s")}";
	}

	private async Task CommitAndPushAsync()
	{
		if (_selectedRow is null)
		{
			return;
		}

		EnsureSelectedRowIsCurrent();

		_isRunning = true;
		AppendConsole("▶ Committing and pushing...");
		StateHasChanged();

		try
		{
			var commitMessage = $"NuGet governance remediation for {_selectedRow.PackageId}";
			var success = await Dashboard.CommitAndPushAsync(_selectedRow, commitMessage, line =>
			{
				AppendConsole(line);
				InvokeAsync(StateHasChanged);
			});

			if (success)
			{
				_completedSteps.Add(WorkflowStep.CommitAndPush);
				AppendConsole("✅ Changes committed and pushed");

				if (_selectedRow.CurrentBranch is not null)
				{
					AppendConsole($"ℹ️ Branch: {_selectedRow.CurrentBranch} | Clean: {_selectedRow.IsWorkingTreeClean} | Synced: {_selectedRow.IsSyncedWithOrigin}");
				}
			}
			else
			{
				AppendConsole("❌ Commit and push failed");
			}
		}
		catch (Exception ex)
		{
			AppendConsole($"❌ Error: {ex.Message}");
		}
		finally
		{
			_isRunning = false;
			StateHasChanged();
		}
	}

