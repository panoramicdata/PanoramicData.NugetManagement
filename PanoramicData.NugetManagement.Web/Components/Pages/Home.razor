@page "/"
@using Microsoft.AspNetCore.Authentication
@using Octokit
@rendermode InteractiveServer
@inject DashboardService Dashboard
@inject DashboardCacheService Cache
@inject PackageDashboardDataProvider DataProvider
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@inject ILogger<Home> Logger
@implements IDisposable

<PageTitle>NuGet Package Governance</PageTitle>

@if (!_isAuthenticated)
{
    <div class="login-page">
        <div class="login-card">
            <div class="login-icon">📦</div>
            <h1>NuGet Governance</h1>
            <p>Sign in with GitHub to assess and remediate your organization's NuGet packages.</p>
            <a href="/login" class="btn btn-primary btn-login">🔑 Sign in with GitHub</a>
        </div>
    </div>
}
else
{
    <header class="app-header">
        <div class="header-brand">
            <span class="brand-icon">📦</span>
            <span class="brand-text">NuGet Governance</span>
        </div>
        <div class="header-actions">
            @if (_isLoading)
            {
                <span class="progress-indicator"><span class="spinner"></span> @_progressMessage</span>
            }
            else if (_lastRefreshUtc > DateTimeOffset.MinValue)
            {
                <span class="progress-indicator" style="opacity:0.5">Last refreshed: @_lastRefreshUtc.ToLocalTime().ToString("HH:mm")</span>
            }
            <button class="btn btn-primary" @onclick="RefreshAsync" disabled="@_isLoading">🔄 Refresh</button>
            <a href="/settings" class="btn">⚙️ Settings</a>
            <a href="/logout" class="btn">👤 @_userName — Sign out</a>
        </div>
    </header>

    <div class="dashboard-content">
    <!-- Summary strip -->
    <div class="summary-strip">
        <div class="summary-card">
            <div class="label">Packages</div>
            <div class="value blue">@_rows.Count</div>
        </div>
        <div class="summary-card">
            <div class="label">Passing</div>
            <div class="value green">@_rows.Count(r => r.Assessment is not null && r.TotalFailures == 0)</div>
        </div>
        <div class="summary-card">
            <div class="label">Failing</div>
            <div class="value red">@_rows.Count(r => r.Assessment is not null && r.TotalErrors > 0)</div>
        </div>
        <div class="summary-card">
            <div class="label">Warnings</div>
            <div class="value amber">@_rows.Count(r => r.Assessment is not null && r.TotalWarnings > 0 && r.TotalErrors == 0)</div>
        </div>
    </div>

    <!-- Main governance table using PDTable -->
    <PDTable @ref="_table"
             TItem="PackageDashboardRow"
             DataProvider="DataProvider"
             KeyField="x => x.PackageId"
             SearchText="@_searchText"
             Click="OnRowClick"
             DoubleClick="OnRowDoubleClick"
             TableClass="governance-table">

        <PDToolbar>
            <PDToolbarTextbox Placeholder="Search packages..."
                              Value="@_searchText"
                              ValueChanged="OnSearchChanged"
                              Width="250px" />
        </PDToolbar>

        <PDColumn TItem="PackageDashboardRow"
                  Field="x => x.PackageId"
                  Title="Package"
                  Sortable="true"
                  Filterable="true"
                  TdClass="text-start">
            <Template>
                @if (context.RepositoryUrl is not null)
                {
                    <a href="@context.RepositoryUrl" target="_blank" class="pkg-name">@context.PackageId</a>
                }
                else
                {
                    <span class="pkg-name">@context.PackageId</span>
                }
                @if (context.IsClonedLocally)
                {
                    @if (context.IsWorkingTreeClean == false)
                    {
                        <span class="git-dirty" title="Working tree has uncommitted changes">●</span>
                    }
                    else if (context.IsWorkingTreeClean == true)
                    {
                        <span class="git-clean" title="Working tree is clean">●</span>
                    }
                }
            </Template>
        </PDColumn>

        <PDColumn TItem="PackageDashboardRow"
                  Field="x => x.LatestVersion"
                  Title="Version"
                  Sortable="true"
                  Filterable="true">
            <Template>
                <span class="pkg-version">@context.LatestVersion</span>
            </Template>
        </PDColumn>

        @foreach (var cat in _categories)
        {
            var category = cat;
            <PDColumn TItem="PackageDashboardRow"
                      Field="x => x.TotalFailures"
                      Id="@($"cat-{category}")"
                      Title="@GetCategoryAbbrev(category)"
                      Sortable="false">
                <Template>
                    @if (context.Assessment is null)
                    {
                        @if (context.Status == PackageStatus.Assessing)
                        {
                            <span class="spinner"></span>
                        }
                        else
                        {
                            <span class="badge-none">—</span>
                        }
                    }
                    else if (context.CategorySummaries.TryGetValue(category, out var summary))
                    {
                        @if (summary.TotalFailures == 0)
                        {
                            <span class="badge badge-pass">✓</span>
                        }
                        else if (summary.Errors > 0)
                        {
                            <span class="badge badge-fail">@summary.TotalFailures</span>
                        }
                        else if (summary.Warnings > 0)
                        {
                            <span class="badge badge-warn">@summary.TotalFailures</span>
                        }
                        else
                        {
                            <span class="badge badge-info">@summary.TotalFailures</span>
                        }
                    }
                    else
                    {
                        <span class="badge-none">—</span>
                    }
                </Template>
            </PDColumn>
        }

        <PDColumn TItem="PackageDashboardRow"
                  Field="x => x.TotalFailures"
                  Id="total"
                  Title="Total"
                  Sortable="true">
            <Template>
                @if (context.Assessment is not null)
                {
                    @if (context.TotalFailures == 0)
                    {
                        <span class="badge badge-pass">0</span>
                    }
                    else if (context.TotalErrors > 0)
                    {
                        <span class="badge badge-fail">@context.TotalFailures</span>
                    }
                    else
                    {
                        <span class="badge badge-warn">@context.TotalFailures</span>
                    }
                }
            </Template>
        </PDColumn>

    </PDTable>

    </div>
}

@code {
    private bool _isAuthenticated;
    private string _userName = string.Empty;
    private string? _accessToken;
    private bool _isLoading;
    private string _progressMessage = string.Empty;
    private List<PackageDashboardRow> _rows = [];
    private AssessmentCategory[] _categories = [];
    private DateTimeOffset _lastRefreshUtc = DateTimeOffset.MinValue;
    private System.Threading.Timer? _autoRefreshTimer;
    private PDTable<PackageDashboardRow>? _table;
    private string _searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext?.User.Identity?.IsAuthenticated == true)
        {
            _isAuthenticated = true;
            _userName = httpContext.User.Identity.Name ?? "User";
            _accessToken = await httpContext.GetTokenAsync("access_token");
            _categories = Enum.GetValues<AssessmentCategory>();

            // Load from cache immediately
            var cached = Cache.GetCachedRows();
            if (cached is not null)
            {
                _rows = cached;
                _lastRefreshUtc = Cache.LastRefreshUtc;
            }

            // Start hourly auto-refresh timer
            _autoRefreshTimer = new System.Threading.Timer(
                OnAutoRefreshTimer,
                null,
                Cache.IsStale ? TimeSpan.Zero : DashboardCacheService.CacheDuration,
                DashboardCacheService.CacheDuration);
        }
    }

    private void OnAutoRefreshTimer(object? state)
    {
        _ = InvokeAsync(async () =>
        {
            if (!_isLoading)
            {
                await RefreshAsync().ConfigureAwait(false);
            }
        });
    }

    private IGitHubClient CreateGitHubClient()
    {
        var client = new GitHubClient(new ProductHeaderValue("PanoramicData.NugetManagement.Web"));
        if (_accessToken is not null)
        {
            client.Credentials = new Credentials(_accessToken);
        }

        return client;
    }

    private async Task RefreshAsync()
    {
        _isLoading = true;
        _progressMessage = "Discovering packages...";
        StateHasChanged();

        try
        {
            var freshRows = await Dashboard.DiscoverPackagesAsync();

            // Merge: preserve existing cached assessments for rows that
            // already have data so the UI never flashes back to a blank state.
            var existingByPackageId = _rows
                .Where(r => r.Assessment is not null)
                .ToDictionary(r => r.PackageId, StringComparer.OrdinalIgnoreCase);

            foreach (var row in freshRows)
            {
                if (existingByPackageId.TryGetValue(row.PackageId, out var existing))
                {
                    row.Assessment = existing.Assessment;
                    row.CategorySummaries = existing.CategorySummaries;
                }
            }

            _rows = freshRows;

            // Cache the merged rows (with preserved assessments) immediately
            Cache.SetRows(_rows);
            await RefreshTableAsync();

            var github = CreateGitHubClient();
            var assessable = _rows.Where(r => r.RepositoryFullName is not null).ToList();

            for (var i = 0; i < assessable.Count; i++)
            {
                var row = assessable[i];
                _progressMessage = $"Assessing package health ({i + 1} / {assessable.Count}): {row.PackageId}...";
                StateHasChanged();

                await Dashboard.AssessRepositoryAsync(row, github);
                await RefreshTableAsync();
            }

            // Mark the full refresh as complete
            Cache.Update(_rows);
            _lastRefreshUtc = Cache.LastRefreshUtc;

            _progressMessage = string.Empty;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to refresh dashboard");
            _progressMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshTableAsync()
    {
        if (_table is not null)
        {
            await _table.RefreshAsync().ConfigureAwait(true);
        }

        StateHasChanged();
    }

    private void OnRowClick(PackageDashboardRow row)
    {
        // Single click — no-op (PDTable handles selection)
    }

    private void OnRowDoubleClick(PackageDashboardRow row)
    {
        Navigation.NavigateTo($"/{Uri.EscapeDataString(row.PackageId)}");
    }

    private async Task OnSearchChanged(string value)
    {
        _searchText = value;
        if (_table is not null)
        {
            await _table.RefreshAsync(_searchText).ConfigureAwait(true);
        }
    }

    private static string GetCategoryAbbrev(AssessmentCategory cat) => cat switch
    {
        AssessmentCategory.CiCd => "CI",
        AssessmentCategory.Versioning => "VER",
        AssessmentCategory.CentralPackageManagement => "CPM",
        AssessmentCategory.NuGetHygiene => "PKG",
        AssessmentCategory.TargetFramework => "TFM",
        AssessmentCategory.BuildQuality => "BLD",
        AssessmentCategory.CodeQuality => "CQ",
        AssessmentCategory.Testing => "TST",
        AssessmentCategory.Serialization => "SER",
        AssessmentCategory.Licensing => "LIC",
        AssessmentCategory.ReadmeBadges => "DOC",
        AssessmentCategory.RepositoryHygiene => "REPO",
        AssessmentCategory.ProjectMetadata => "META",
        AssessmentCategory.HttpClient => "HTTP",
        AssessmentCategory.Documentation => "XML",
        AssessmentCategory.DependencyAutomation => "DEP",
        AssessmentCategory.CommunityHealth => "COM",
        _ => cat.ToString()[..3].ToUpperInvariant()
    };

    public void Dispose()
    {
        _autoRefreshTimer?.Dispose();
    }
}
