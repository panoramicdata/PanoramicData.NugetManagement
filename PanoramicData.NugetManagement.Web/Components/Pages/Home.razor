		}

		_chatMessages.Add(new ChatMsg { IsUser = true, Text = _chatInput });
		_chatMessages.Add(new ChatMsg { IsUser = false, Text = "I'm not connected to an AI backend yet — this is a placeholder. Future versions will provide contextual help about your packages and governance rules." });
