	// === Git safety guard methods ===

	private bool IsFixEnabled()
	{
		if (_selectedRow is null || _isAssessing || _isRunning || !_selectedRow.IsClonedLocally)
		{
			return false;
		}

		if (_selectedRow.Assessment is null ||
			!_selectedRow.Assessment.RuleResults.Any(r => !r.Passed && Dashboard.IsAutoRemediable(r)))
		{
			return false;
		}

		return _selectedRow.CurrentBranch == "main"
			&& _selectedRow.IsSyncedWithOrigin != false;
	}

	private string? GetFixBlockReason()
	{
		if (_selectedRow is null || !_selectedRow.IsClonedLocally)
		{
			return "Repository is not cloned locally";
		}

		if (_selectedRow.CurrentBranch != "main")
		{
			return $"Must be on 'main' branch (currently on '{_selectedRow.CurrentBranch ?? "unknown"}')";
		}

		if (_selectedRow.IsSyncedWithOrigin == false)
		{
			return "Local branch is not in sync with origin — run Git Sync first";
		}

		return null;
	}

	private string GetFixAllTooltip()
	{
		if (_isAssessing)
		{
			return "Assessment in progress";
		}

		if (_isRunning)
		{
			return "Another operation is running";
		}

		if (_selectedRow is null || !_selectedRow.IsClonedLocally)
		{
			return "Clone the repository first";
		}

		if (_selectedRow.Assessment is null)
		{
			return "Assess the package first";
		}

		if (!_selectedRow.Assessment.RuleResults.Any(r => !r.Passed && Dashboard.IsAutoRemediable(r)))
		{
			return "No auto-remediable issues found";
		}

		return GetFixBlockReason() ?? "Auto-fix remediable issues";
	}

