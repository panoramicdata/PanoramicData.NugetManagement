	// === Workflow step indicators ===

	private enum WorkflowStep
	{
		GitSync,
		Reassess,
		Fix,
		FixWithAi,
		Build,
		Test,
		CommitAndPush,
		Publish
	}

	private bool IsStepDone(WorkflowStep step)
	{
		// Explicit tracking for steps that don't map to PackageStatus
		if (_completedSteps.Contains(step))
		{
			return true;
		}

		// PackageStatus-based tracking for workflow steps
		return _selectedRow?.Status switch
		{
			PackageStatus.GitSynced => step == WorkflowStep.GitSync,
			PackageStatus.Assessed => step is WorkflowStep.GitSync or WorkflowStep.Reassess,
			PackageStatus.Remediated => step is WorkflowStep.GitSync or WorkflowStep.Reassess or WorkflowStep.Fix,
			PackageStatus.BuildFailed => step is WorkflowStep.GitSync or WorkflowStep.Reassess or WorkflowStep.Fix,
			PackageStatus.BuildSucceeded => step is WorkflowStep.GitSync or WorkflowStep.Reassess or WorkflowStep.Fix or WorkflowStep.Build,
			PackageStatus.TestsFailed => step is WorkflowStep.GitSync or WorkflowStep.Reassess or WorkflowStep.Fix or WorkflowStep.Build,
			PackageStatus.TestsPassed => step is WorkflowStep.GitSync or WorkflowStep.Reassess or WorkflowStep.Fix or WorkflowStep.Build or WorkflowStep.Test,
			PackageStatus.Published => step is WorkflowStep.GitSync or WorkflowStep.Reassess or WorkflowStep.Fix or WorkflowStep.Build or WorkflowStep.Test or WorkflowStep.Publish,
			_ => false
		};
	}

	private bool IsPublishDone() => _selectedRow?.Status == PackageStatus.Published;

	private bool IsStepFailed(WorkflowStep step)
	{
		if (_failedSteps.Contains(step))
		{
			return true;
		}

		return _selectedRow?.Status switch
		{
			PackageStatus.BuildFailed => step == WorkflowStep.Build,
			PackageStatus.TestsFailed => step == WorkflowStep.Test,
			_ => false
		};
	}

	private string GetStepCssClass(WorkflowStep step)
	{
		if (IsStepFailed(step))
		{
			return "toolbar-step-failed";
		}

		return IsStepDone(step) ? "toolbar-step-done" : "";
	}

