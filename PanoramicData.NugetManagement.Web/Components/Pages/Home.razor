	// === Package detail methods (merged from PackageDetail.razor) ===

	/// <summary>
	/// Ensures <c>_selectedRow</c> points to the current object in <c>_rows</c>.
	/// After <see cref="RefreshAsync"/> replaces <c>_rows</c> with fresh objects,
	/// <c>_selectedRow</c> can become stale. This method re-resolves the reference
	/// and, when the old and new objects differ, copies any assessment data across
	/// so that in-flight mutations are not lost.
	/// </summary>
	private void EnsureSelectedRowIsCurrent()
	{
		if (_selectedRow is null)
		{
			return;
		}

		var current = _rows.FirstOrDefault(r =>
			string.Equals(r.PackageId, _selectedRow.PackageId, StringComparison.OrdinalIgnoreCase));

		if (current is null)
		{
			return;
		}

		if (!ReferenceEquals(current, _selectedRow))
		{
			// Carry forward any assessment already on the old reference
			if (_selectedRow.Assessment is not null && current.Assessment is null)
			{
				current.Assessment = _selectedRow.Assessment;
				current.CategorySummaries = _selectedRow.CategorySummaries;
				current.Status = _selectedRow.Status;
				current.StatusMessage = _selectedRow.StatusMessage;
			}

			_selectedRow = current;
		}
	}

	private async Task PersistSelectedRowUpdateAsync()
	{
		if (_selectedRow is null)
		{
			return;
		}

		var rowIndex = _rows.FindIndex(r => string.Equals(r.PackageId, _selectedRow.PackageId, StringComparison.OrdinalIgnoreCase));
		if (rowIndex >= 0)
		{
			_rows[rowIndex] = _selectedRow;
		}

		Cache.UpsertRow(_selectedRow);
		_lastRefreshUtc = Cache.LastRefreshUtc;
		await RefreshTableAsync();
	}

	private CancellationToken BeginCancelableOperation(WorkflowStep step)
	{
		_operationCts?.Dispose();
		_operationCts = new CancellationTokenSource();
		_activeWorkflowStep = step;

		if (_selectedRow is not null)
		{
			_statusBeforeOperation = _selectedRow.Status;
			_statusMessageBeforeOperation = _selectedRow.StatusMessage;
		}

		return _operationCts.Token;
	}

	private async Task CancelCurrentOperationAsync()
	{
		if (_operationCts is null || _activeWorkflowStep is null)
		{
			return;
		}

		AppendConsole($"⏹️ Cancelling {GetWorkflowStepDisplayName(_activeWorkflowStep.Value).ToLowerInvariant()}...");
		_operationCts.Cancel();
		await InvokeAsync(StateHasChanged);
	}

	private void RestoreStatusAfterCancellation()
	{
		if (_selectedRow is null)
		{
			return;
		}

		if (_statusBeforeOperation.HasValue)
		{
			_selectedRow.Status = _statusBeforeOperation.Value;
		}

		if (_statusMessageBeforeOperation is not null)
		{
			_selectedRow.StatusMessage = _statusMessageBeforeOperation;
		}
	}

	private void EndCancelableOperation()
	{
		_operationCts?.Dispose();
		_operationCts = null;
		_activeWorkflowStep = null;
		_statusBeforeOperation = null;
		_statusMessageBeforeOperation = null;
	}

   private bool IsStepRunning(WorkflowStep step)
		=> _activeWorkflowStep == step && (_isRunning || _isAssessing || _isLoading);

	private static string GetWorkflowStepDisplayName(WorkflowStep step) => step switch
	{
		WorkflowStep.GitSync => "Git Sync",
		WorkflowStep.Reassess => "Re-assess",
		WorkflowStep.Fix => "Fix",
		WorkflowStep.FixWithAi => "Fix with AI",
		WorkflowStep.Build => "Build",
		WorkflowStep.Test => "Test",
		WorkflowStep.CommitAndPush => "Commit & Push",
		WorkflowStep.Publish => "Publish",
		_ => step.ToString()
	};

	private string GetToolbarStepText(WorkflowStep step)
		=> IsStepRunning(step) ? $"{GetWorkflowStepDisplayName(step)}..." : GetWorkflowStepDisplayName(step);

	private static string GetToolbarStepIconCss(WorkflowStep step, bool isRunning) => isRunning
		? "fas fa-spinner fa-spin"
		: step switch
		{
			WorkflowStep.GitSync => "fas fa-sync",
			WorkflowStep.Reassess => "fas fa-sync-alt",
			WorkflowStep.Fix => "fas fa-wrench",
			WorkflowStep.FixWithAi => "fas fa-magic",
			WorkflowStep.Build => "fas fa-hammer",
			WorkflowStep.Test => "fas fa-flask",
