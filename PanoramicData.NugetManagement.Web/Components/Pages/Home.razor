@page "/"
@page "/{PackageId?}"
@using Microsoft.AspNetCore.Authentication
@using Microsoft.Extensions.Options
@using Octokit
@rendermode InteractiveServer
@inject DashboardService Dashboard
@inject DashboardCacheService Cache
@inject PackageDashboardDataProvider DataProvider
@inject NavTreeDataProvider NavDataProvider
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@inject ILogger<Home> Logger
@inject IJSRuntime JS
@inject IOptions<AppSettings> SettingsOptions
@inject RuntimeSettingsService RuntimeSettings
@inject IdeDetectionService IdeDetection
@inject LocalFileSystemDataProvider FileSystemDataProvider
@implements IDisposable

<PageTitle>NuGet Governance</PageTitle>

@if (!_isAuthenticated)
{
	<div class="login-page">
		<div class="login-card">
			<div class="login-icon">📦</div>
			<h1>NuGet Governance</h1>
			<p>Sign in with GitHub to assess and remediate your organization's NuGet packages.</p>
			<a href="/login" class="btn btn-primary btn-login"><i class="fas fa-key"></i> Sign in with GitHub</a>
		</div>
	</div>
}
else
{
	<div class="spa-body">
		<PDSplitter Direction="SplitDirection.Horizontal" GutterSize="4" ExpandToMin="true">

			<!-- Left: Navigation panel (logo at top, filter, tree below) -->
				<PDSplitPanel Size="1" MinSize="240" CssClass="spa-panel spa-nav-panel">
					<div class="nav-tree-container">
						<div class="nav-brand-header">
							<span class="brand-icon">📦</span>
							<span class="brand-text">NuGet Governance</span>
						</div>
						<div class="nav-tree-filter">
							<div class="input-group input-group-sm">
								<span class="input-group-text"><i class="fas fa-filter"></i></span>
								<input type="text"
									   class="form-control form-control-sm"
									   placeholder="Filter repos (regex)..."
									   value="@_treeFilterText"
									   @oninput="OnTreeFilterInput" />
								@if (!string.IsNullOrEmpty(_treeFilterText))
								{
									<button class="btn btn-outline-secondary btn-sm" type="button" @onclick="ClearTreeFilter" title="Clear filter">
										<i class="fas fa-times"></i>
									</button>
								}
							</div>
							@if (_treeFilterError is not null)
							{
								<div class="filter-error">@_treeFilterError</div>
							}
						</div>
						<div class="nav-tree-scroll">
							<PDTree @ref="_navTree"
									TItem="NavItem"
									DataProvider="NavDataProvider"
									KeyField="x => x.Key"
									ParentKeyField="x => x.ParentKey!"
									TextField="x => x.Text"
									IsLeaf="x => x.IsLeaf"
									IconCssClass="(item, _) => item.IconCss"
									ToolTip="GetNavItemTooltip"
									AllowSelection="true"
									ShowRoot="true"
									SelectionChange="OnNavSelectionChanged" />
						</div>
					</div>
				</PDSplitPanel>

			<!-- Centre: Breadcrumbs + Toolbar + Content + Console -->
			<PDSplitPanel Size="3" MinSize="400" CssClass="spa-panel spa-content-panel">
				<div class="centre-column">

					<!-- Breadcrumb bar at the very top -->
					<div class="breadcrumb-bar">
						<div class="breadcrumb-trail">
							<a class="breadcrumb-link" @onclick="NavigateToDashboard" @onclick:preventDefault>
								<i class="fas fa-tachometer-alt"></i> Dashboard
							</a>
							@if (_selectedRow is not null)
							{
								<span class="breadcrumb-sep">›</span>
								<span class="breadcrumb-current">
									<i class="@GetPackageHealthIcon(_selectedRow)"></i>
									@_selectedRow.PackageId
									<span class="pkg-version">@_selectedRow.LatestVersion</span>
								</span>
								@if (_selectedRow.IsClonedLocally)
								{
									<span class="breadcrumb-sep">|</span>
									@if (_selectedRow.IsWorkingTreeClean == false)
									{
										<span class="git-dirty-badge" title="Working tree has uncommitted changes">● Dirty</span>
									}
									else if (_selectedRow.IsWorkingTreeClean == true)
									{
										<span class="git-clean-badge" title="Working tree is clean">● Clean</span>
									}
									@if (_selectedRow.CurrentBranch is not null)
									{
										<span class="@(_selectedRow.CurrentBranch == "main" ? "git-clean-badge" : "git-dirty-badge")" title="Current branch">⎇ @_selectedRow.CurrentBranch</span>
									}
									@if (_selectedRow.IsSyncedWithOrigin == false)
									{
										<span class="git-dirty-badge" title="Not in sync with origin">⇅ Out of sync</span>
									}
									else if (_selectedRow.IsSyncedWithOrigin == true)
									{
										<span class="git-clean-badge" title="In sync with origin">⇅ Synced</span>
									}
									<!-- Inline git actions after repo info -->
									<button class="btn btn-xs btn-breadcrumb" @onclick="GitSyncAsync" disabled="@_isRunning" title="Fetch, pull --rebase, push">
										<i class="fas fa-sync"></i>
									</button>
									<button class="btn btn-xs btn-breadcrumb" @onclick="BuildAsync" disabled="@_isRunning" title="Build">
										<i class="fas fa-hammer"></i>
									</button>
									<button class="btn btn-xs btn-breadcrumb" @onclick="RunTestsAsync" disabled="@_isRunning" title="Test">
										<i class="fas fa-flask"></i>
									</button>
									<button class="btn btn-xs btn-breadcrumb btn-breadcrumb-publish" @onclick="RunPublishAsync" disabled="@(!IsPublishEnabled())" title="@GetPublishTooltip()">
										<i class="fas fa-rocket"></i>
									</button>
								}
								else
								{
									<span class="breadcrumb-sep">|</span>
									<button class="btn btn-xs btn-breadcrumb" @onclick="GitSyncAsync" disabled="@_isRunning" title="Clone and sync repository">
										<i class="fas fa-sync"></i>
									</button>
								}
								@if (_selectedCategory is not null)
								{
									<span class="breadcrumb-sep">›</span>
									<span class="breadcrumb-current" title="@_selectedCategory">@_selectedCategory</span>
								}
								@if (_selectedRuleId is not null)
								{
									<span class="breadcrumb-sep">›</span>
									<span class="breadcrumb-current" title="@_selectedRuleId">@_selectedRuleId</span>
								}
                           }
						</div>
						<div class="breadcrumb-right">
							@if (_isLoading || _isAssessing)
							{
								<span class="progress-indicator"><span class="spinner"></span> @_progressMessage</span>
							}
							else if (_lastRefreshUtc > DateTimeOffset.MinValue)
							{
								<span class="progress-indicator" style="opacity:0.5">@_lastRefreshUtc.ToLocalTime().ToString("HH:mm")</span>
							}
							<a href="/logout" class="btn btn-xs btn-breadcrumb" title="Sign out">
								<i class="fas fa-user"></i> @_userName
							</a>
						</div>
					</div>

					<!-- Toolbar — workflow order: Git Sync → Re-assess → Fix → Fix with AI → Build → Test → Commit & Push → Publish → Publish (skip) -->
						<PDToolbar CssClass="main-toolbar">
							<PDToolbarButton Key="refresh"
											 Text="Refresh"
											 IconCssClass="fas fa-sync-alt"
											 CssClass="btn-primary"
											 IsVisible="@(_currentView is NavView.Dashboard or NavView.None)"
											 IsEnabled="@(!_isLoading)"
											 ToolTip="Refresh package list"
											 Click="OnToolbarClick" />

							<PDToolbarButton Key="git-sync"
											 Text="Git Sync"
											 IconCssClass="fas fa-sync"
											 CssClass="@GetStepCssClass(WorkflowStep.GitSync)"
										 IsVisible="@(_selectedRow is not null)"
											 IsEnabled="@(!_isRunning)"
										 ToolTip="Clone if needed, then fetch, pull --rebase, push"
											 Click="OnToolbarClick" />

							<PDToolbarButton Key="reassess"
											 Text="Re-assess"
											 IconCssClass="fas fa-sync-alt"
											 CssClass="@GetStepCssClass(WorkflowStep.Reassess)"
											 IsVisible="@(_currentView is NavView.Dashboard or NavView.PackageDetail or NavView.CategoryDetail or NavView.RuleDetail)"
											 IsEnabled="@(!_isAssessing)"
											 ToolTip="@(_currentView == NavView.Dashboard ? "Re-assess all repos" : "Re-assess this package")"
											 Click="OnToolbarClick" />

							<PDToolbarButton Key="fix"
											 Text="Fix"
											 IconCssClass="fas fa-wrench"
											 CssClass="@GetStepCssClass(WorkflowStep.Fix)"
											 IsVisible="@(_currentView is NavView.PackageDetail or NavView.CategoryDetail or NavView.RuleDetail && _selectedRow is not null)"
											 IsEnabled="@IsFixEnabled()"
											 ToolTip="@GetFixAllTooltip()"
											 Click="OnToolbarClick" />

							<PDToolbarButton Key="open-ide"
										 Text="Open IDE"
										 IconCssClass="fas fa-code"
										 CssClass="@GetStepCssClass(WorkflowStep.FixWithAi)"
										 IsVisible="@(_currentView is NavView.PackageDetail or NavView.CategoryDetail or NavView.RuleDetail && _selectedRow is not null)"
										 IsEnabled="@IsOpenIdeEnabled()"
										 ToolTip="@GetOpenIdeTooltip()"
										 Click="OnToolbarClick" />

							<PDToolbarButton Key="copy-ai-prompt"
										 Text="Copy AI Prompt"
										 IconCssClass="fas fa-copy"
										 CssClass="@GetStepCssClass(WorkflowStep.FixWithAi)"
										 IsVisible="@(_currentView is NavView.PackageDetail or NavView.CategoryDetail or NavView.RuleDetail && _selectedRow is not null)"
										 IsEnabled="@IsFixWithAiEnabled()"
										 ToolTip="@GetFixWithAiTooltip()"
										 Click="OnToolbarClick" />

							<PDToolbarSeparator IsVisible="@(_selectedRow?.IsClonedLocally == true)" />

							<PDToolbarButton Key="build"
											 Text="Build"
											 IconCssClass="fas fa-hammer"
											 CssClass="@GetStepCssClass(WorkflowStep.Build)"
											 IsVisible="@(_selectedRow?.IsClonedLocally == true)"
											 IsEnabled="@(!_isRunning)"
											 ToolTip="Build the solution"
											 Click="OnToolbarClick" />

							<PDToolbarButton Key="test"
											 Text="Test"
											 IconCssClass="fas fa-flask"
											 CssClass="@GetStepCssClass(WorkflowStep.Test)"
											 IsVisible="@(_selectedRow?.IsClonedLocally == true)"
											 IsEnabled="@(!_isRunning)"
											 ToolTip="Run unit tests"
											 Click="OnToolbarClick" />

							<PDToolbarSeparator IsVisible="@(_selectedRow?.IsClonedLocally == true)" />

							<PDToolbarButton Key="commit-and-push"
											 Text="Commit & Push"
											 IconCssClass="fas fa-cloud-upload-alt"
											 CssClass="@GetStepCssClass(WorkflowStep.CommitAndPush)"
											 IsVisible="@(_selectedRow?.IsClonedLocally == true)"
											 IsEnabled="@(!_isRunning)"
											 ToolTip="Commit changes, fetch, rebase and push to origin"
											 Click="OnToolbarClick" />

							<PDToolbarButton Key="publish"
										 Text="Publish"
										 IconCssClass="fas fa-rocket"
										 CssClass="@(IsPublishDone() ? "btn-success toolbar-step-done" : "btn-success")"
										 IsVisible="@(_selectedRow?.IsClonedLocally == true)"
										 IsEnabled="@IsPublishEnabled()"
										 ToolTip="@GetPublishTooltip()"
										 Click="OnToolbarClick" />

							<PDToolbarButton Key="publish-skip-integration"
										 Text="Publish (skip integration)"
										 IconCssClass="fas fa-forward"
										 CssClass="btn-warning"
										 IsVisible="@(_selectedRow?.IsClonedLocally == true)"
										 IsEnabled="@IsPublishSkipIntegrationEnabled()"
										 ToolTip="@GetPublishSkipIntegrationTooltip()"
										 Click="OnToolbarClick" />

							<PDToolbarPlaceholder ShiftRight="true">
								<button class="btn btn-xs @(_currentView == NavView.Settings ? "btn-console-active" : "")"
										@onclick="NavigateToSettings"
										title="Application settings">
									<i class="fas fa-cog"></i>
								</button>
								<button class="btn btn-xs @(_consoleVisible ? "btn-console-active" : "")"
										@onclick="ToggleConsole"
										title="Toggle console panel">
									<i class="fas fa-terminal"></i>
								</button>
							</PDToolbarPlaceholder>
						</PDToolbar>

					<!-- Content + optional Console (vertical split when console visible) -->
					@if (_consoleVisible)
					{
						<div class="centre-content-area">
							<PDSplitter Direction="SplitDirection.Vertical" GutterSize="4" ExpandToMin="true">
								<PDSplitPanel Size="3" MinSize="150" CssClass="spa-panel spa-main-content">
									@RenderCurrentView()
								</PDSplitPanel>

								<PDSplitPanel Size="1" MinSize="80" CssClass="spa-panel spa-console-panel">
									@RenderConsolePanel()
								</PDSplitPanel>
							</PDSplitter>
						</div>
					}
					else
					{
						<div class="centre-content-area spa-main-content">
							@RenderCurrentView()
						</div>
					}
				</div>
			</PDSplitPanel>

			<!-- Right: Merlin AI Chat -->
			<PDSplitPanel Size="1" MinSize="280" CssClass="spa-panel spa-chat-panel">
				<div class="merlin-chat-container">
					<div class="merlin-chat-header">
						<i class="fas fa-hat-wizard"></i> Merlin
					</div>
					<div class="merlin-chat-messages">
						@if (_chatMessages.Count == 0)
						{
							<div class="merlin-welcome">
								<div class="merlin-avatar">🧙</div>
								<p>Hello! I'm <strong>Merlin</strong>, your AI assistant.</p>
								<p class="text-muted">Select a package and ask about assessment results, remediation, or best practices.</p>
							</div>
						}
						else
						{
							@foreach (var msg in _chatMessages)
							{
								<div class="merlin-msg @(msg.IsUser ? "merlin-msg-user" : "merlin-msg-ai")">
									<span class="merlin-msg-icon">@(msg.IsUser ? "👤" : "🧙")</span>
									<div class="merlin-msg-content">@msg.Text</div>
								</div>
							}
						}
					</div>
					<div class="merlin-chat-input">
						<input type="text" @bind="_chatInput" @bind:event="oninput"
							   @onkeydown="OnChatKeyDown"
							   placeholder="Ask Merlin..." />
						<button class="btn btn-sm btn-primary" @onclick="SendChatMessage" disabled="@(string.IsNullOrWhiteSpace(_chatInput))">
							<i class="fas fa-paper-plane"></i>
						</button>
					</div>
				</div>
			</PDSplitPanel>

		</PDSplitter>
	</div>
}

<PDFileModal @ref="_fileModal" DataProvider="FileSystemDataProvider" />

@code {
	// === Route parameter ===
	[Parameter]
	public string? PackageId { get; set; }

	// === Auth state ===
	private bool _isAuthenticated;
	private string _userName = string.Empty;
	private string? _accessToken;

	// === Navigation state ===
	private PDTree<NavItem>? _navTree;
	private NavView _currentView = NavView.Dashboard;
	private string? _selectedPackageId;
	private AssessmentCategory? _selectedCategory;
	private string? _selectedRuleId;
	private PackageDashboardRow? _selectedRow;
	private string _treeFilterText = string.Empty;
	private string? _treeFilterError;
	private System.Threading.Timer? _treeFilterDebounce;

	// === Dashboard state ===
	private bool _isLoading;
	private string _progressMessage = string.Empty;
	private List<PackageDashboardRow> _rows = [];
	private AssessmentCategory[] _categories = [];
	private DateTimeOffset _lastRefreshUtc = DateTimeOffset.MinValue;
	private System.Threading.Timer? _autoRefreshTimer;
	private PDTable<PackageDashboardRow>? _table;
	private string _searchText = string.Empty;

	// === Package detail state ===
	private bool _isAssessing;
	private bool _isRunning;

	// === Console state ===
	private bool _consoleVisible = true;
	private bool _consoleScrollPending;
	private List<ConsoleLine> _consoleLines = [];
	private ElementReference _consoleElement;
	private string? _lastPromptText;
	private bool _copyFeedback;
	private bool _consoleCopyFeedback;
	private WorkflowStep? _lastFailedWorkflowStep;
	private WorkflowStep? _activeWorkflowStep;
	private CancellationTokenSource? _operationCts;
	private PackageStatus? _statusBeforeOperation;
	private string? _statusMessageBeforeOperation;

	// === Merlin chat state ===
	private string _chatInput = string.Empty;
	private List<ChatMsg> _chatMessages = [];

	// === IDE state ===
	private string? _preferredIdeId;

	// === Workflow step completion state ===
	private readonly HashSet<WorkflowStep> _completedSteps = [];
	private readonly HashSet<WorkflowStep> _failedSteps = [];

	// === Settings state ===
	private PDFileModal? _fileModal;
	private string? _localReposRoot;
	private bool _folderSaved;
	private bool _includeInfoInAiPrompt;

	// === Lifecycle ===

	protected override async Task OnInitializedAsync()
	{
		var httpContext = HttpContextAccessor.HttpContext;
		if (httpContext?.User.Identity?.IsAuthenticated != true)
		{
			return;
		}

		_isAuthenticated = true;
		_userName = httpContext.User.Identity.Name ?? "User";
		_accessToken = await httpContext.GetTokenAsync("access_token");
		_categories = Enum.GetValues<AssessmentCategory>();
		_localReposRoot = RuntimeSettings.LocalReposRoot;
		_preferredIdeId = RuntimeSettings.PreferredIdeId;
		_includeInfoInAiPrompt = RuntimeSettings.IncludeInfoInAiPrompt;

		// Load from cache immediately
		var cached = Cache.GetCachedRows();
		if (cached is not null)
		{
			_rows = cached;
			_lastRefreshUtc = Cache.LastRefreshUtc;
		}

		// If a PackageId was in the URL, select it
		if (!string.IsNullOrEmpty(PackageId))
		{
			_selectedRow = _rows.FirstOrDefault(r =>
				string.Equals(r.PackageId, PackageId, StringComparison.OrdinalIgnoreCase));
			if (_selectedRow is not null)
			{
				_selectedPackageId = _selectedRow.PackageId;
				_currentView = NavView.PackageDetail;
			}
		}

		// Start hourly auto-refresh timer
		_autoRefreshTimer = new System.Threading.Timer(
			OnAutoRefreshTimer,
			null,
			Cache.IsStale ? TimeSpan.Zero : DashboardCacheService.CacheDuration,
			DashboardCacheService.CacheDuration);
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			try
			{
				var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "consoleVisible");
				if (stored is not null && bool.TryParse(stored, out var visible))
				{
					_consoleVisible = visible;
					StateHasChanged();
				}
			}
			catch
			{
				// localStorage may not be available
			}
		}

		if (_consoleScrollPending && _consoleVisible)
		{
			_consoleScrollPending = false;
			try
			{
				await JS.InvokeVoidAsync("eval", "document.querySelector('.detail-console-output')?.scrollTo(0, document.querySelector('.detail-console-output').scrollHeight)");
			}
			catch
			{
				// Element may not exist yet
			}
		}
	}

	// === Navigation ===

	private void OnNavSelectionChanged(TreeNode<NavItem> node)
	{
		if (node.Data is null)
		{
			return;
		}

		var item = node.Data;
		_currentView = item.View;
		_selectedPackageId = item.PackageId;
		_selectedCategory = item.Category;
		_selectedRuleId = item.RuleId;

		if (item.PackageId is not null)
		{
			var newRow = _rows.FirstOrDefault(r =>
				string.Equals(r.PackageId, item.PackageId, StringComparison.OrdinalIgnoreCase));
			if (newRow != _selectedRow)
           {
				_completedSteps.Clear();
				_failedSteps.Clear();
				_lastFailedWorkflowStep = null;
			}

			_selectedRow = newRow;
		}
		else
		{
			_selectedRow = null;
			_completedSteps.Clear();
			_failedSteps.Clear();
			_lastFailedWorkflowStep = null;
		}

		StateHasChanged();
	}

	private void NavigateToDashboard()
	{
		_currentView = NavView.Dashboard;
		_selectedRow = null;
		_selectedPackageId = null;
		_selectedCategory = null;
		_selectedRuleId = null;
		_completedSteps.Clear();
		_failedSteps.Clear();
      _lastFailedWorkflowStep = null;
		StateHasChanged();
	}

	private void NavigateToSettings()
	{
		_currentView = NavView.Settings;
		_selectedRow = null;
		_selectedPackageId = null;
		_selectedCategory = null;
		_selectedRuleId = null;
		_completedSteps.Clear();
		_failedSteps.Clear();
      _lastFailedWorkflowStep = null;
		StateHasChanged();
	}

	private async Task ToggleConsole()
	{
		_consoleVisible = !_consoleVisible;
		try
		{
			await JS.InvokeVoidAsync("localStorage.setItem", "consoleVisible", _consoleVisible.ToString().ToLowerInvariant());
		}
		catch
		{
			// localStorage may not be available
		}

		StateHasChanged();
	}

	private void OnTreeFilterInput(ChangeEventArgs e)
	{
		_treeFilterText = e.Value?.ToString() ?? string.Empty;
		_treeFilterError = null;

		// Debounce: wait 300ms after the user stops typing before applying the filter
		_treeFilterDebounce?.Dispose();
		_treeFilterDebounce = new System.Threading.Timer(
			_ => InvokeAsync(ApplyTreeFilter),
			null,
			300,
			Timeout.Infinite);
	}

	private async Task ApplyTreeFilter()
	{
		if (string.IsNullOrWhiteSpace(_treeFilterText))
		{
			NavDataProvider.FilterRegex = null;
			_treeFilterError = null;
		}
		else
		{
			try
			{
				NavDataProvider.FilterRegex = new System.Text.RegularExpressions.Regex(
					_treeFilterText,
					System.Text.RegularExpressions.RegexOptions.IgnoreCase,
					TimeSpan.FromMilliseconds(200));
				_treeFilterError = null;
			}
			catch (System.Text.RegularExpressions.RegexParseException)
			{
				_treeFilterError = "Invalid regex";
				return;
			}
		}

		if (_navTree is not null)
		{
			await _navTree.RefreshAsync().ConfigureAwait(true);
		}

		StateHasChanged();
	}

	private async Task ClearTreeFilter()
	{
		_treeFilterText = string.Empty;
		_treeFilterError = null;
		NavDataProvider.FilterRegex = null;

		if (_navTree is not null)
		{
			await _navTree.RefreshAsync().ConfigureAwait(true);
		}

		StateHasChanged();
	}

	// === Toolbar ===

	private async Task OnToolbarClick(KeyedEventArgs<MouseEventArgs> args)
	{
		switch (args.Key)
		{
			case "refresh":
				await RefreshAsync();
				break;
			case "fix":
				await FixAllAsync();
				break;
			case "fix-with-ai":
				await FixWithAiAsync();
				break;
			case "open-ide":
				OpenInIde();
				break;
			case "copy-ai-prompt":
				await CopyPromptToClipboardAsync();
				break;
			case "reassess":
						if (_currentView == NavView.Dashboard)
						{
							await ReassessAllReposAsync();
						}
						else
						{
							await ReassessAllAsync();
						}

						break;
				case "build":
				await BuildAsync();
				break;
			case "test":
				await RunTestsAsync();
				break;
			case "git-sync":
					await GitSyncAsync();
					break;
			case "commit-and-push":
				await CommitAndPushAsync();
				break;
			case "publish":
				await RunPublishAsync();
				break;
			case "publish-skip-integration":
				await RunPublishAsync();
				break;
		}
	}

	// === Render Fragments ===

	private RenderFragment RenderCurrentView() => __builder =>
	{
		switch (_currentView)
		{
			case NavView.Dashboard:
			case NavView.None:
				<div class="spa-placeholder">
					<i class="fas fa-hand-point-left fa-2x"></i>
					<p>Select an item from the navigation tree</p>
				</div>
				break;
			case NavView.PackageDetail:
				@RenderPackageDetailView()
				break;
			case NavView.CategoryDetail:
				@RenderCategoryDetailView()
				break;
			case NavView.RuleDetail:
