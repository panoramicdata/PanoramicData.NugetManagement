	private async Task FixAllAsync()
	{
		if (_selectedRow is null || !_selectedRow.IsClonedLocally)
		{
			return;
		}

		EnsureSelectedRowIsCurrent();

		var blockReason = GetFixBlockReason();
		if (blockReason is not null)
		{
			AppendConsole($"❌ Cannot fix: {blockReason}");
			StateHasChanged();
			return;
		}

		_isRunning = true;
		AppendConsole("▶ Applying all auto-remediations...");
		StateHasChanged();

		try
		{
			var applied = await Dashboard.ApplyRemediationsAsync(_selectedRow, line =>
			{
				AppendConsole(line);
				InvokeAsync(StateHasChanged);
			});

			await Dashboard.RefreshGitStatusAsync(_selectedRow);
			AppendConsole($"✅ Applied {applied.Count} remediation(s)");

			// Re-assess
			_isAssessing = true;
			_progressMessage = "Re-assessing...";
			StateHasChanged();
			await Dashboard.AssessLocalRepositoryAsync(_selectedRow);
           await PersistSelectedRowUpdateAsync();

			// Report remaining issues that have no auto-fix
			var remaining = _selectedRow.Assessment?.RuleResults
				.Where(r => !r.Passed && !Dashboard.IsAutoRemediable(r))
				.ToList() ?? [];
			if (remaining.Count > 0)
			{
				foreach (var r in remaining)
				{
					AppendConsole($"⚠️ [{r.RuleId}] {r.RuleName} — no auto-fix available");
				}

				AppendConsole($"ℹ️ {remaining.Count} issue(s) require manual fix. Use \"Open IDE\" and \"Copy AI Prompt\" to fix with AI assistance.");
			}
			else if (_selectedRow.TotalFailures == 0)
			{
				AppendConsole("🎉 No remaining issues — all rules pass.");
			}
		}
		catch (Exception ex)
		{
			AppendConsole($"❌ Error: {ex.Message}");
		}
		finally
		{
			_isRunning = false;
			_isAssessing = false;
			_progressMessage = string.Empty;
			StateHasChanged();
		}
	}

